rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == "davidcordero1012@gmail.com"
      );
    }

    match /people/{personId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPerson(incoming());
      allow update: if isSignedIn() && isValidPerson(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['collaborationCount']) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'team', 'collaborationCount', 'isEmergencyDept', 'limitOverride']))
      );
      allow delete: if isAdmin();
    }

    function isValidPerson(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.team in ['1', '2', '3', '4'] &&
             data.collaborationCount is int && data.collaborationCount >= 0 &&
             data.isEmergencyDept is bool &&
             (data.keys().size() <= 6);
    }

    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidAssignment(incoming());
      allow update: if isSignedIn() && isValidAssignment(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['confirmedCollaborationIds', 'status']) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['assignedPeopleIds', 'confirmedCollaborationIds', 'status']))
      );
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "davidcordero1012@gmail.com");
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isValidAssignment(data) {
      return data.date is string &&
             data.assignedPeopleIds is list &&
             data.confirmedCollaborationIds is list &&
             data.status in ['draft', 'confirmed'] &&
             (!data.keys().hasAll(['type']) || data.type in ['morning', 'afternoon']);
    }
  }
}
